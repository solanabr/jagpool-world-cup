# =====================================================================
# Supabase
# =====================================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# =====================================================================
# Solana
# =====================================================================
# Use a paid/dedicated RPC in prod — the public endpoint rate-limits getParsedTokenAccountsByOwner.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# JagSOL mint. Defaults to the mainnet mint in code if unset (lib/solana/jagsol.ts).
NEXT_PUBLIC_JAGSOL_MINT=jag58eRBC1c88LaAsRPspTMvoKJPbnzw9p9fREzHqyV

# =====================================================================
# App
# =====================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
SIWS_DOMAIN=localhost:3000

# =====================================================================
# Secrets — generate with `openssl rand -base64 48`
# WALLET_PASSWORD_PEPPER is permanent — rotating locks out wallet users.
# =====================================================================
CRON_SECRET=
WALLET_PASSWORD_PEPPER=

# =====================================================================
# Admin bootstrap
# =====================================================================
# No env var here. Admin = `users.is_admin = true` (single source of truth).
# Bootstrap the first admin via SQL:
#   UPDATE public.users SET is_admin = true WHERE wallet_address = '<pubkey>';
# After that, promote other users from /admin/users in the app.
